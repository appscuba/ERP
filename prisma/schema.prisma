generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  CAJERO
  CONTADOR
  SUPERVISOR
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

enum InvoiceStatus {
  ISSUED
  PAID
  VOIDED
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
  RETURN
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  VOID
  PERMISSION_CHANGE
  ADMIN_ACTION
}

model Company {
  id                String   @id @default(cuid())
  name              String
  legalName         String?
  taxId             String?
  currency          String   @default("USD")
  defaultTaxRate    Decimal  @db.Decimal(5, 2)
  invoicePrefix     String   @default("INV")
  salePrefix        String   @default("SALE")
  fiscalYearStart   DateTime?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users             User[]
  categories        Category[]
  products          Product[]
  clients           Client[]
  sales             Sale[]
  invoices          Invoice[]
  settings          Setting[]
  inventoryMovements InventoryMovement[]
  accountingEntries AccountingEntry[]
}

model User {
  id                 String     @id @default(cuid())
  companyId          String
  company            Company    @relation(fields: [companyId], references: [id])
  email              String
  password           String
  name               String
  roleId             String
  role               Role       @relation(fields: [roleId], references: [id])
  isActive           Boolean    @default(true)
  mustChangePassword Boolean    @default(true)
  lastLoginAt        DateTime?
  deletedAt          DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  auditLogs          AuditLog[]
  sales              Sale[]
  createdInvoices    Invoice[]  @relation("InvoiceCreatedBy")
  voidedInvoices     Invoice[]  @relation("InvoiceVoidedBy")
  voidedSales        Sale[]     @relation("SaleVoidedBy")

  @@unique([companyId, email])
  @@index([companyId, roleId])
}

model Role {
  id          String       @id @default(cuid())
  name        RoleName     @unique
  permissions Permission[] @relation("RolePermissions")
  users       User[]
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  roles       Role[]   @relation("RolePermissions")
}

model Category {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  name        String
  description String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@unique([companyId, name])
}

model Product {
  id                String              @id @default(cuid())
  companyId         String
  company           Company             @relation(fields: [companyId], references: [id])
  sku               String
  barcode           String?
  name              String
  description       String?
  price             Decimal             @db.Decimal(12, 2)
  cost              Decimal             @db.Decimal(12, 2)
  stock             Int                 @default(0)
  minStock          Int                 @default(0)
  categoryId        String
  category          Category            @relation(fields: [categoryId], references: [id])
  isActive          Boolean             @default(true)
  deletedAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  saleItems         SaleItem[]
  inventoryMovements InventoryMovement[]

  @@unique([companyId, sku])
  @@index([companyId, categoryId])
}

model Client {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  email     String?
  phone     String?
  taxId     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales     Sale[]
  invoices  Invoice[]

  @@index([companyId, taxId])
}

model Sale {
  id          String      @id @default(cuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  saleNo      String
  invoiceNo   String?     @unique
  total       Decimal     @db.Decimal(12, 2)
  tax         Decimal     @db.Decimal(12, 2)
  subtotal    Decimal     @db.Decimal(12, 2)
  status      SaleStatus  @default(COMPLETED)
  voidReason  String?
  voidedById  String?
  voidedBy    User?       @relation("SaleVoidedBy", fields: [voidedById], references: [id])
  voidedAt    DateTime?
  clientId    String?
  client      Client?     @relation(fields: [clientId], references: [id])
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  items       SaleItem[]
  invoice     Invoice?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([companyId, saleNo])
  @@index([companyId, createdAt])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal  @db.Decimal(12, 2)
  tax       Decimal  @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
}

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  invoiceNo     String
  saleId        String?       @unique
  sale          Sale?         @relation(fields: [saleId], references: [id])
  clientId      String?
  client        Client?       @relation(fields: [clientId], references: [id])
  status        InvoiceStatus @default(ISSUED)
  subtotal      Decimal       @db.Decimal(12, 2)
  tax           Decimal       @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  voidReason    String?
  voidedById    String?
  voidedBy      User?         @relation("InvoiceVoidedBy", fields: [voidedById], references: [id])
  voidedAt      DateTime?
  createdById   String
  createdBy     User          @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([companyId, invoiceNo])
  @@index([companyId, issueDate])
}

model InventoryMovement {
  id          String                @id @default(cuid())
  companyId   String
  company     Company               @relation(fields: [companyId], references: [id])
  productId   String
  product     Product               @relation(fields: [productId], references: [id])
  type        InventoryMovementType
  quantity    Int
  reason      String?
  reference   String?
  createdById String?
  createdBy   String?
  createdAt   DateTime              @default(now())

  @@index([companyId, productId, createdAt])
}

model AccountingEntry {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  entryNo      String
  accountCode  String
  description  String
  debit        Decimal  @db.Decimal(12, 2)
  credit       Decimal  @db.Decimal(12, 2)
  reference    String?
  createdAt    DateTime @default(now())

  @@unique([companyId, entryNo])
  @@index([companyId, createdAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  companyId  String?
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  module     String
  recordId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  hash       String
  prevHash   String?
  createdAt  DateTime    @default(now())

  @@index([companyId, module, recordId, createdAt])
  @@index([createdAt])
}

model Setting {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  key        String
  value      String
  isPrivate  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([companyId, key])
}
